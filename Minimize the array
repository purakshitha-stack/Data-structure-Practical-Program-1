class Solution:
    def getMinDiff(self, arr, k):
        n = len(arr)
        arr.sort()

        ans = arr[n-1] - arr[0]

        for i in range(n-1):
            if arr[i+1] - k < 0:
                continue

            min_h = min(arr[0] + k, arr[i+1] - k)
            max_h = max(arr[i] + k, arr[n-1] - k)

            ans = min(ans, max_h - min_h)

        return ans
