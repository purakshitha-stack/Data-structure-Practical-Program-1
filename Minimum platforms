class Solution:
    def minPlatform(self, arr, dep):
        n = len(arr)

        arr.sort()
        dep.sort()

        i = 1
        j = 0
        platform = 1
        result = 1

        while i < n and j < n:

            if arr[i] <= dep[j]:
                platform += 1
                i += 1
            else:
                platform -= 1
                j += 1

            result = max(result, platform)

        return result
