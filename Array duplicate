class Solution:
    def findDuplicates(self, arr):
        count = {}
        result = []
        
        for num in arr:
            if num in count:
                count[num] += 1
            else:
                count[num] = 1
        
        for num in count:
            if count[num] == 2:
                result.append(num)
                
        return result
