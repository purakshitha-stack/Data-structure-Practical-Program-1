class Solution:
    def removeLoop(self, head):
        slow = head
        fast = head
        
        # Detect cycle
        while fast and fast.next:
            slow = slow.next
            fast = fast.next.next
            
            if slow == fast:
                break
        
        if slow != fast:
            return
        
        slow = head
        
        if slow == fast:
            while fast.next != slow:
                fast = fast.next
            fast.next = None
        else:
            while slow.next != fast.next:
                slow = slow.next
                fast = fast.next
            fast.next = None
