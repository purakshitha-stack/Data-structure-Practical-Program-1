class Solution:
    def majorityElement(self, arr):
        count = {}
        
        for num in arr:
            if num in count:
                count[num] += 1
            else:
                count[num] = 1
        
        n = len(arr)
        
        for num in count:
            if count[num] > n // 2:
                return num
        
        return -1
